# ~/.bashrc — kept as a working fallback alongside zsh.

# If not running interactively, don't do anything
case $- in
    *i*) ;;
      *) return;;
esac

# History
HISTCONTROL=ignoreboth
shopt -s histappend
HISTSIZE=10000
HISTFILESIZE=20000

# Update window size after each command
shopt -s checkwinsize

# make less more friendly for non-text input files
[ -x /usr/bin/lesspipe ] && eval "$(SHELL=/bin/sh lesspipe)"

# enable color support of ls and add handy aliases
if [ -x /usr/bin/dircolors ]; then
    test -r ~/.dircolors && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"
    alias grep='grep --color=auto'
fi

# Modern CLI aliases (fall back gracefully when a tool is absent)
if command -v eza >/dev/null 2>&1; then
    alias ls='eza --group-directories-first --icons=auto'
    alias ll='eza -lah --group-directories-first --icons=auto --git'
    alias la='eza -a --group-directories-first --icons=auto'
else
    alias ls='ls --color=auto'
    alias ll='ls -alF'
    alias la='ls -A'
fi
command -v bat     >/dev/null 2>&1 && alias cat='bat --paging=never'
command -v lazygit >/dev/null 2>&1 && alias lg='lazygit'
command -v nvim    >/dev/null 2>&1 && alias vim='nvim' && alias vi='nvim'

# enable programmable completion
if ! shopt -oq posix; then
  if [ -f /usr/share/bash-completion/bash_completion ]; then
    . /usr/share/bash-completion/bash_completion
  elif [ -f /etc/bash_completion ]; then
    . /etc/bash_completion
  fi
fi

# PATH
export PATH="$PATH:/usr/local/go/bin"
export PATH="$HOME/.local/bin:$PATH"

# Tool integrations — mise first so it puts mise-managed tools (starship,
# zoxide, atuin, …) on PATH before their init runs.
[ -x "$HOME/.local/bin/mise" ] && eval "$("$HOME/.local/bin/mise" activate bash)"
command -v starship >/dev/null 2>&1 && eval "$(starship init bash)"
command -v zoxide   >/dev/null 2>&1 && eval "$(zoxide init bash)"
command -v atuin    >/dev/null 2>&1 && eval "$(atuin init bash --disable-up-arrow)"

# OSC 7: report cwd so terminals (wezterm, etc.) can open new tabs/panes in the
# same directory. Appended to PROMPT_COMMAND so it coexists with atuin et al.
_osc7_report_cwd() {
  local i c enc="" LC_ALL=C
  for (( i = 0; i < ${#PWD}; i++ )); do
    c=${PWD:i:1}
    case "$c" in
      [-_.~/A-Za-z0-9]) enc+="$c" ;;
      *) printf -v c '%%%02X' "'$c"; enc+="$c" ;;
    esac
  done
  printf '\e]7;file://%s%s\e\\' "$HOSTNAME" "$enc"
}
PROMPT_COMMAND="_osc7_report_cwd${PROMPT_COMMAND:+; $PROMPT_COMMAND}"

# pnpm
export PNPM_HOME="$HOME/.local/share/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# bun
export BUN_INSTALL="$HOME/.bun"
[ -d "$BUN_INSTALL/bin" ] && export PATH="$BUN_INSTALL/bin:$PATH"

# Vite+ (https://viteplus.dev)
[ -f "$HOME/.vite-plus/env" ] && . "$HOME/.vite-plus/env"
