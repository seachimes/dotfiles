[user]
	# No global identity on purpose. The identity is chosen per repo from the
	# remote's org (see [include]). useConfigOnly makes git REFUSE to commit when
	# nothing matches, so you can never commit under the wrong account.
	useConfigOnly = true
[include]
	# Machine-local, hand-maintained, NOT tracked here. Map each org's remote URL
	# to an identity file. Example ~/.config/git/identity.gitconfig:
	#
	#   [includeIf "hasconfig:remote.*.url:git@github.com:my-personal/**"]
	#       path = ~/.config/git/id-personal
	#   [includeIf "hasconfig:remote.*.url:git@github.com:ACME-ORG/**"]
	#       path = ~/.config/git/id-work
	#   [includeIf "hasconfig:remote.*.url:git@github.com:OTHER-WORK-ORG/**"]
	#       path = ~/.config/git/id-work        # several orgs -> one account
	#
	# and each id-<account> file just sets [user] name/email. Add https:// forms
	# too if you clone over HTTPS. Missing file is fine (git skips it); until you
	# add a matching rule, useConfigOnly blocks commits in that repo.
	path = ~/.config/git/identity.gitconfig
[init]
	defaultBranch = main
[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	line-numbers = true
	syntax-theme = Coldark-Dark
[merge]
	# zdiff3 needs git >= 2.35; fall back to diff3 on older git (e.g. distro builds)
	conflictStyle = {{ if semverCompare ">=2.35.0" (output "git" "version" | regexFind "[0-9]+\\.[0-9]+\\.[0-9]+") }}zdiff3{{ else }}diff3{{ end }}
[diff]
	colorMoved = default
	algorithm = histogram
[push]
	autoSetupRemote = true
[pull]
	rebase = true
[fetch]
	prune = true
[alias]
	st = status
	co = checkout
	br = branch
	ci = commit
	lg = log --graph --oneline --decorate --all
	last = log -1 HEAD
	unstage = reset HEAD --
