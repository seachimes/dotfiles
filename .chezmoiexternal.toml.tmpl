# External dependencies fetched and kept up to date by chezmoi.
# antidote: fast, minimal zsh plugin manager.
[".antidote"]
    type = "git-repo"
    url = "https://github.com/mattmc3/antidote.git"
    refreshPeriod = "168h"

# tpm: tmux plugin manager (plugins themselves are installed by tpm on first run).
[".config/tmux/plugins/tpm"]
    type = "git-repo"
    url = "https://github.com/tmux-plugins/tpm.git"
    refreshPeriod = "168h"
